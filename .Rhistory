View(inv_tp_data)
# Ahora calculo la abundancia media por taxon y bin de TP
abundance_by_bin <- inv_tp_data |>
group_by(taxon, tp_bin) |>
summarise(mean_abundance = mean(abundance, na.rm = TRUE), .groups = "drop")
View(abundance_by_bin)
# Ahora calculo la abundancia media por taxon y bin de TP
abundance_by_bin <- inv_tp_data |>
filter(!is.na(tp_bin)) |>
group_by(taxon, tp_bin) |>
summarise(mean_abundance = mean(abundance, na.rm = TRUE), .groups = "drop")
# Y ahora grafico las curvas de abundancia por taxon a lo largo del gradiente de TP
ggplot(abundance_by_bin, aes(x = tp_bin, y = mean_abundance, group = taxon, color = taxon)) +
geom_line() +
geom_point() +
labs(title = "Curvas de Abundancia por Taxon a lo largo del Gradiente de TP",
x = "Bin de TP",  y = "Abundancia Media") +
theme_classic() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Y ahora grafico las curvas de abundancia por taxon a lo largo del gradiente de TP
