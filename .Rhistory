wa_inv_train_f<- inv_train_long_f |>
left_join(inv_optima_f, by = "taxon") |>
group_by(site, visit) |>
summarise(logtp_wa_f = sum(optimum_logtp * abundance) / sum(abundance),
tp_wa_inv_f = 10^logtp_wa_f,
.groups = "drop"
)
wa_inv_test_f <- inv_test_long_f |>
left_join(inv_optima_f, by = "taxon") |>
group_by(site, visit) |>
summarise(logtp_wa_f = sum(optimum_logtp * abundance) / sum(abundance),
tp_wa_inv_f = 10^logtp_wa_f,
.groups = "drop"
)
